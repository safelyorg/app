{
  "manifest_version": 3,
  "name": "Safely",
  "version": "1.0.0",
  "description": "Secure your online transactions. It checks the seller risk score and protect payment everywhere you shop.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "pkg/wasm.js",
        "pkg/wasm_bg.wasm"
      ],
      "matches": [
        "<all_urls>"
      ]
    },
    {
      "resources": [
        "icons/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "action": {
    "default_title": "Safely",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "css": [
        "css/panel.css"
      ],
      "js": [
        "js/core/state.js",
        "js/scrapers/olx.js",
        "js/scrapers/facebook.js",
        "js/scrapers/index.js",
        "js/core/api.js",
        "js/core/panel.js",
        "js/tabs/risk.js",
        "js/tabs/intelligence.js",
        "js/tabs/protect.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://safely.sh/*"
      ],
      "js": [
        "js/auth-bridge.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
